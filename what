        if spam then
            for _, part in pairs(workspace:GetDescendants()) do
                if part:IsA("BasePart") and not part.Anchored then
                    if not part:IsDescendantOf(LocalPlayer.Character) then
                        local isCore = part.Name == "Torso" or part.Name == "Head" or 
                                      part.Name == "Right Arm" or part.Name == "Left Arm" or
                                      part.Name == "Right Leg" or part.Name == "Left Leg" or
