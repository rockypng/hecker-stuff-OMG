    -- 2021: Simulation radius still works but needs different approach
    spawn(function()
        while true do
            RunService.Heartbeat:Wait()
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= LocalPlayer then
                    pcall(function()
                        -- 2021: These properties are still valid
                        LocalPlayer.MaximumSimulationRadius = 1e9
                        LocalPlayer.SimulationRadius = 1e9
                        v.MaximumSimulationRadius = 0
                        v.SimulationRadius = 0
                    end)
                end
            end
        end
    end)

    local Mouse = LocalPlayer:GetMouse()
    local claimedParts = {} -- Track parts we own
    local frozenParts = {} -- Track frozen parts

    -- 2021: Force ownership function
    local function ForceOwnership(part)
        if not part or not part:IsA("BasePart") then return false end
        if part.Anchored then return false end
        if claimedParts[part] then return true end
        
        -- Method 1: Physics nudge + SetNetworkOwner (2021 compatible)
        local success = pcall(function()
            -- Small velocity change to trigger ownership
            part.AssemblyLinearVelocity = part.AssemblyLinearVelocity + Vector3.new(
                math.random(-1, 1),
                math.random(-1, 1),
                math.random(-1, 1)
            )
            task.wait(0.02)
            part:SetNetworkOwner(LocalPlayer)
        end)
        
        if success then
            claimedParts[part] = true
            return true
        end
        
        -- Method 2: Touch simulation (2021 fallback)
        pcall(function()
            local char = LocalPlayer.Character
            if char and char.PrimaryPart then
                local oldPos = char.PrimaryPart.Position
                char.PrimaryPart.Position = part.Position + Vector3.new(0, 3, 0)
                task.wait(0.05)
                char.PrimaryPart.Position = oldPos
                part:SetNetworkOwner(LocalPlayer)
            end
        end)
        
        claimedParts[part] = true
        return true
    end

    -- 2021: Teleport function with ownership + anti-revert
    local function TeleportParts(targetPosition)
        local char = LocalPlayer.Character
        if not char then return end
        
        local sound2 = Instance.new("Sound")
        sound2.SoundId = "rbxassetid://3398620867"
        sound2.Parent = game:GetService("SoundService")
        
        local teleported = 0
        
        for _, part in pairs(workspace:GetDescendants()) do
            if part:IsA("BasePart") and not part.Anchored then
                -- Skip player character parts
                if not part:IsDescendantOf(char) then
                    local name = part.Name
                    local isCore = name == "Torso" or name == "Head" or 
                                  name == "Right Arm" or name == "Left Arm" or
                                  name == "Right Leg" or name == "Left Leg" or
                                  name == "HumanoidRootPart"
                    
                    if not isCore then
                        -- Force ownership first
                        if ForceOwnership(part) then
                            -- Teleport
                            part.CFrame = CFrame.new(targetPosition + Vector3.new(
                                math.random(-2, 2),
                                0,
                                math.random(-2, 2)
                            ))
                            
                            -- 2021: Lock position with BodyPosition to prevent revert
                            if not part:FindFirstChild("BodyPosition_Lock") then
                                local bp = Instance.new("BodyPosition")
                                bp.Name = "BodyPosition_Lock"
                                bp.Position = part.Position
                                bp.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                                bp.P = 50000
                                bp.D = 1000
                                bp.Parent = part
                                frozenParts[part] = bp
                            else
                                part.BodyPosition_Lock.Position = part.Position
                            end
                            
                            -- Zero out velocity to stop rubberbanding
                            part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                            part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                            
                            teleported = teleported + 1
                        end
                    end
                end
            end
        end
        
        sound2:Play()
        print("Teleported " .. teleported .. " parts to target")
        return teleported
    end

    -- 2021: Anti-revert loop - constantly refresh ownership and position
    local function AntiRevertLoop()
        for part, _ in pairs(claimedParts) do
            if part and part:IsA("BasePart") and not part.Anchored then
                pcall(function()
                    -- Refresh ownership every few frames
                    if math.random(1, 5) == 1 then
                        part:SetNetworkOwner(LocalPlayer)
                    end
                    
                    -- Keep position locked if frozen
                    if frozenParts[part] then
                        frozenParts[part].Position = part.Position
                    end
                    
                    -- Small nudge to prevent server reclaim
                    if part.AssemblyLinearVelocity.Magnitude < 0.5 then
                        part.AssemblyLinearVelocity = Vector3.new(
                            math.random(-1, 1) * 0.1,
                            math.random(-1, 1) * 0.1,
                            math.random(-1, 1) * 0.1
                        )
                    end
                end)
            else
                claimedParts[part] = nil
                frozenParts[part] = nil
            end
        end
    end

    -- Start anti-revert loop
    RunService.Heartbeat:Connect(function()
        AntiRevertLoop()
    end)

    -- Execute teleport to player
    local function ExecuteTeleport(targetName)
        local target = Players:FindFirstChild(targetName)
        if not target or not target.Character then
            print("Player not found or no character")
            return
        end
        
        local head = target.Character:FindFirstChild("Head")
        if not head then
            print("Target has no head")
            return
        end
        
        local targetPos = head.Position
        TeleportParts(targetPos)
    end

